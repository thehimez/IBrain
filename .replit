modules = ["nodejs-20", "bash", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GBrain API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GBrain Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GBrain Mobile"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && bun run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "GBrain API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run src/cli.ts serve --http --port 3001 --bind 0.0.0.0 --print-admin-token"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "GBrain Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run src/cli.ts jobs work --concurrency 2"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "GBrain Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && bunx expo start --port 8081 --tunnel"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[userenv]

[userenv.shared]
GBRAIN_CHAT_MODEL = "openai:gpt-4o"
GBRAIN_EMBEDDING_DIMENSIONS = "1536"
GBRAIN_EMBEDDING_MODEL = "openai:text-embedding-3-small"
GBRAIN_EXPANSION_MODEL = "openai:gpt-4o-mini"
GOOGLE_REDIRECT_URI = "https://5c4c8529-498e-4fca-a15c-582b9dd75a87-00-11o34mhlk557i.pike.replit.dev/api/auth/google/callback"
GBRAIN_MODEL = "openai:gpt-4o"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "bun run src/cli.ts serve --http --port ${PORT:-8080} --bind 0.0.0.0"]
build = ["bash", "-c", "cd frontend && bun install --frozen-lockfile && bun run build"]
