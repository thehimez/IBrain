modules = ["nodejs-20", "bash", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GBrain API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GBrain Worker"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && bun run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "GBrain API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run src/cli.ts serve --http --port 3001 --bind 0.0.0.0 --print-admin-token"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "GBrain Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run src/cli.ts jobs work --concurrency 2"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[userenv]

[userenv.shared]
GBRAIN_CHAT_MODEL = "openai:gpt-4o"
GBRAIN_EMBEDDING_DIMENSIONS = "1536"
GBRAIN_EMBEDDING_MODEL = "openai:text-embedding-3-small"
GBRAIN_EXPANSION_MODEL = "openai:gpt-4o-mini"
GOOGLE_REDIRECT_URI = "https://a1c0b49a-8223-4a49-a0be-ed740d973ecb-00-oqkczda9e1ee.pike.replit.dev/api/auth/google/callback"
